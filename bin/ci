#!/usr/bin/env bash

set -euo pipefail

run() {
  printf '\n==> '
  printf '%q ' "$@"
  printf '\n'
  "$@"
}

run bash scripts/check_spec_requirements.sh

if ! bundle check; then
  run bundle install
fi

run env RAILS_ENV=test bin/rails db:prepare
run env RAILS_ENV=test bundle exec rspec
run bundle exec rubocop
run bundle exec brakeman --no-pager
run bundle exec bundler-audit check --update
run env RAILS_ENV=test bin/rails zeitwerk:check
run env RAILS_ENV=test bin/rails tailwindcss:build
run env RAILS_ENV=test SECRET_KEY_BASE_DUMMY=1 bin/rails assets:precompile
run env RAILS_ENV=test bin/rails runner 'abort unless Rails.application.class.name == "CompanyFinance::Application"'

printf '\nCI local concluído com sucesso.\n'

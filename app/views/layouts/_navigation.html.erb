<% context_label = local_assigns[:context_label] %>

<header class="no-print border-b border-slate-200 bg-white">
  <nav class="page-container flex min-h-16 flex-wrap items-center justify-between gap-3 py-3" aria-label="Navegação principal">
    <div class="flex min-w-0 items-center gap-3">
      <%= link_to "Finance Manager", root_path, class: "rounded-sm text-base font-semibold tracking-tight text-slate-950 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-700" %>
      <% if context_label.present? %>
        <span class="border-l border-slate-300 pl-3 text-sm font-medium text-slate-600"><%= context_label %></span>
      <% end %>
    </div>

    <div class="flex flex-wrap items-center gap-3 text-sm">
      <%= link_to "Início", root_path, class: "rounded-sm font-medium text-slate-700 underline-offset-4 hover:text-slate-950 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-700" %>
      <% unless Rails.env.production? %>
        <span class="rounded-full border border-amber-300 bg-amber-50 px-2.5 py-1 font-medium text-amber-900">Ambiente de desenvolvimento</span>
      <% end %>
    </div>
  </nav>
</header>

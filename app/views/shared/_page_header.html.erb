<% description = local_assigns[:description] %>
<% actions = local_assigns[:actions] %>

<header class="mb-8 flex min-w-0 flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
  <div class="min-w-0">
    <h1 class="text-balance break-words text-2xl font-bold tracking-tight text-slate-950 sm:text-3xl"><%= title %></h1>
    <% if description.present? %>
      <p class="mt-2 max-w-3xl text-pretty text-sm leading-6 text-slate-600 sm:text-base"><%= description %></p>
    <% end %>
  </div>

  <% if actions.present? %>
    <div class="no-print flex shrink-0 flex-wrap items-center gap-2"><%= actions %></div>
  <% end %>
</header>

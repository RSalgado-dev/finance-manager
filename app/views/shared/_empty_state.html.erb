<% action = local_assigns[:action] %>

<section class="rounded-lg border border-dashed border-slate-300 bg-white px-5 py-10 text-center sm:px-8" data-ui="empty-state">
  <h2 class="text-base font-semibold text-slate-950"><%= title %></h2>
  <p class="mx-auto mt-2 max-w-xl text-sm leading-6 text-slate-600"><%= description %></p>
  <% if action.present? %>
    <div class="no-print mt-5 flex flex-wrap justify-center gap-2"><%= action %></div>
  <% end %>
</section>

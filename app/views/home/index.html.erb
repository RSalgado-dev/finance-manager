<% content_for :title, "Início" %>

<section class="mx-auto max-w-4xl py-6 sm:py-10" aria-label="Apresentação">
  <%= render "shared/page_header",
             title: "Finance Manager",
             description: "A fundação técnica e visual está sendo preparada para a futura gestão financeira operacional de empresas." %>

  <div class="grid gap-4 sm:grid-cols-2">
    <%= render "shared/card",
               title: "Estado atual",
               content: safe_join([
                 status_badge("Em desenvolvimento", tone: :warning),
                 tag.p("A aplicação ainda não oferece funcionalidades de negócio.", class: "mt-3")
               ]) %>

    <%= render "shared/card",
               title: "Escopo desta etapa",
               content: "A identidade básica está disponível, enquanto empresas acessíveis e operações financeiras ainda serão integradas gradualmente." %>
  </div>

  <div class="mt-6">
    <%= render "shared/empty_state",
               title: "Nenhuma operação disponível",
               description: "As próximas funcionalidades serão adicionadas gradualmente conforme o planejamento do projeto." %>
  </div>
</section>

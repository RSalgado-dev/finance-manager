# Fixed development toolchain
RUBY_VERSION=3.4.10
BUNDLER_VERSION=2.7.2
RAILS_VERSION=8.1.3
POSTGRES_IMAGE=postgres:17.10-bookworm

# Host identity used when building the non-root app user
LOCAL_UID=1000
LOCAL_GID=1000

# Development-only PostgreSQL credentials; never reuse in production
POSTGRES_USER=app
POSTGRES_PASSWORD=development_only
POSTGRES_DB=company_finance_development

# Application connection settings inside Docker Compose
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=app
DATABASE_PASSWORD=development_only
DATABASE_NAME=company_finance_development
DATABASE_TEST_NAME=company_finance_test
